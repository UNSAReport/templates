{
  "mode": "multi",
  "components": {
    "code-block": "^1.0.0",
    "lab-section": "^1.0.0",
    "page-header": "^1.0.0",
    "basic-info-table": "^1.0.0"
  },
  "entries": {
    "root": [
      { "kind": "file", "src": "lib.typ", "dest": "lib.typ", "updatable": true },
      { "kind": "file", "src": "flake.nix", "dest": "flake.nix" },
      { "kind": "file", "src": "functions.typ", "dest": "functions.typ", "updatable": true },
      { "kind": "dir", "src": "img/fixed", "dest": "img/fixed", "updatable": true },
      { "kind": "file", "src": "README.md", "dest": "README.md" }
    ],
    "labFiles": [
      { "kind": "file", "src": "report.typ", "dest": "{lab}/report.typ" },
      { "kind": "file", "src": "bibliography.bib", "dest": "{lab}/bibliography.bib" },
      { "kind": "dir", "src": "sections", "dest": "{lab}/sections", "updatable": true }
    ]
  }
}
